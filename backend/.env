# yt-connect-test/backend/.env
# Ye values daalo — real project ka .env se copy karo

PORT=5000
NODE_ENV=development

# MongoDB — real project wala hi use karo ya alag test DB banao
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/yt-connect-test

# JWT — koi bhi random string chalega test ke liye
JWT_ACCESS_SECRET=test_secret_key_minimum_32_characters_long_abcdefgh
JWT_ACCESS_EXPIRES=15m

# Redis — Upstash wala
REDIS_URL=rediss://:PASSWORD@HOST.upstash.io:6379

# Frontend URL
CLIENT_URL=http://localhost:3000

# YouTube OAuth — Google Console se
YOUTUBE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=YOUR_CLIENT_SECRET
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/v1/youtube/callback
