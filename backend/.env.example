PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/dbname
JWT_ACCESS_SECRET=64_char_random_string_here
REDIS_URL=rediss://:PASSWORD@host.upstash.io:6379
